# File: kinetix-studio/backend/.env.example
# This file defines the backend environment variables for local execution.

APP_NAME=Kinetix Studio API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000
STORAGE_ROOT=storage
FFMPEG_EXECUTABLE=ffmpeg
BLENDER_EXECUTABLE=
BLENDER_TEMPLATE_BLEND=assets/mixamo_template.blend
BLENDER_BONE_PREFIX=mixamorig:
DEFAULT_EXPORT_FPS=30
K2_ENABLED=true
K2_API_KEY=
K2_BASE_URL=https://api.k2think.ai/v1/chat/completions
K2_MODEL_NAME=MBZUAI-IFM/K2-Think-v2
K2_TIMEOUT_SECONDS=45