# File: kinetix-studio/.gitignore
# This file excludes local build outputs, environment files, and generated media.

frontend/.next/
frontend/node_modules/
frontend/.env.local
backend/.env
backend/__pycache__/
backend/app/__pycache__/
backend/storage/uploads/*
backend/storage/exports/*
backend/storage/jobs/*
!backend/storage/uploads/.gitkeep
!backend/storage/exports/.gitkeep
!backend/storage/jobs/.gitkeep
*.env